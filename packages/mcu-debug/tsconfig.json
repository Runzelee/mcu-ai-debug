{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@mcu-debug/shared": [
        "../shared/src/index"
      ],
      "@mcu-debug/shared/*": [
        "../shared/*"
      ]
    },
    "target": "ES2022",
    "module": "CommonJS",
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    "plugins": [{
      "name": "typescript-strict-plugin"
    }],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}
